---
import '@/styles/global.css';

interface Props {
  title?: string;
}

const { title = '공팔무한' } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="flex flex-row">
      <img src="/assets/0800_black.png" alt="logo" width="104" height="36" />
    </header>
    <main class="flex-1 flex flex-col">
      <slot />
    </main>
  </body>
</html>
